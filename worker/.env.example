# ──────────────────────────────────────────────────────────────
#  Akira Worker — Variables de entorno
#  Copiá este archivo a .env y completá los valores.
#  Este archivo NUNCA se sube a Git.
# ──────────────────────────────────────────────────────────────

# URL del servidor en Render (sin barra al final)
RENDER_URL=https://tu-app.onrender.com

# Clave secreta compartida entre el servidor y el worker.
# Debe ser la misma que WORKER_SECRET en el .env del backend.
# Generá una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKER_SECRET=genera_una_clave_aleatoria_aqui

# Cadena de conexión a MongoDB (la misma que usa el backend)
MONGO_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/akira

# Clave de cifrado AES-256 — la misma que usa el backend para descifrar las API keys
# IMPORTANTE: debe ser EXACTAMENTE la misma que ENCRYPTION_KEY en Render
# Copiala desde: Render Dashboard → akira-cloud → Environment → ENCRYPTION_KEY
# Debe tener al menos 32 caracteres
ENCRYPTION_KEY=genera_una_clave_de_32_caracteres_minimo
# Directorio donde se guardan las sesiones de WhatsApp (relativo al worker)
# Por defecto: ../sessions (carpeta sessions en la raíz del proyecto)
# WA_SESSIONS_PATH=../sessions
