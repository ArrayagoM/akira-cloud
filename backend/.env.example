# ─────────────────────────────────────────────────────────────
#  AKIRA CLOUD — Variables de entorno del backend
#  Copiá este archivo como .env y completá los valores.
#  Nunca subas tu .env al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Servidor ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Ejemplo Atlas: mongodb+srv://usuario:password@cluster0.xxx.mongodb.net/akira
MONGO_URI=mongodb://localhost:27017/akira

# ── JWT ───────────────────────────────────────────────────────
# Generá un secret seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_de_64_caracteres_minimo
JWT_EXPIRES_IN=7d

# ── Cifrado AES-256-GCM ───────────────────────────────────────
# Mínimo 16 caracteres. Generá uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: si cambiás esta clave, todas las API Keys cifradas quedan ilegibles.
ENCRYPTION_KEY=cambia_esto_por_una_clave_aleatoria_de_minimo_16_chars

# ── URLs públicas ─────────────────────────────────────────────
# En desarrollo: BACKEND_URL es la URL de ngrok (ver sección Ngrok)
# En producción: la URL pública del backend en Render
BACKEND_URL=https://tu-backend.onrender.com
FRONTEND_URL=http://localhost:3000

# ── Sesiones de WhatsApp ──────────────────────────────────────
WA_SESSIONS_PATH=./sessions

# ── MercadoPago — Plataforma (suscripciones de la app) ────────
# Access Token de TU cuenta de MP (no del cliente)
# Obtenelo en: https://www.mercadopago.com.ar/developers
MP_PLATFORM_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
# Webhook secret para verificar notificaciones (opcional pero recomendado)
MP_PLATFORM_WEBHOOK_SECRET=

# ── Ngrok (webhooks locales en desarrollo) ────────────────────
# Conseguí tu token gratis en: https://dashboard.ngrok.com
# Sin esto, los webhooks de MercadoPago no funcionan en desarrollo.
NGROK_AUTH_TOKEN=
NGROK_DOMAIN=

# ── OAuth Google ──────────────────────────────────────────────
# Creá credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── OAuth Facebook ────────────────────────────────────────────
# Creá una app en: https://developers.facebook.com
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/facebook/callback

# ── Worker local (arquitectura híbrida) ──────────────────────
# Clave compartida entre el servidor y el worker que corre en tu PC.
# Generá una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si no la configurás, los bots intentarán correr directamente en Render (no recomendado).
WORKER_SECRET=

# ── Admin inicial ─────────────────────────────────────────────
# Usado por: npm run seed:admin
ADMIN_EMAIL=admin@akiracloud.com
ADMIN_PASSWORD=CambiameEsto123!
ADMIN_NOMBRE=Admin
